# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Workspace files (personal IDE settings)
*.code-workspace

# Backup files
*.bak

# Exploratory Test Files
src/lib/animation/__tests__/deadlift-pose-robustness.test.ts
src/lib/animation/__tests__/deadlift-visualizer-extremes.test.ts
src/lib/biomechanics/__tests__/verification_audit.test.ts

# Lint/warning artifacts
.eslint-warnings*
.warnings-detailed.txt

# Debug Screenshots
*.png
*.jpg
!public/**/*.png
!public/**/*.jpg

# Build Caches
.npm-cache/

# Claude Code local settings
.claude/

# Audit artifacts
audit-artifacts/
